{
  "entities": {
    "User": {
      "title": "User",
      "description": "SMM Client representation holding wallet states and credential checks",
      "type": "object",
      "properties": {
        "username": { "type": "string", "description": "Unique user credentials identifier" },
        "email": { "type": "string", "description": "Email address of the client profile" },
        "password": { "type": "string", "description": "Account password displayed to the administrator" },
        "balance": { "type": "number", "description": "Total available credits in Indian Rupees (INR)" },
        "isFirstDeposit": { "type": "boolean", "description": "Indicates if the client is eligible for the 5% first-deposit premium" },
        "createdAt": { "type": "string", "description": "Creation timestamp ISO line" },
        "referralCode": { "type": "string", "description": "Unique 6-character personal alphanumeric code for referral campaign" },
        "referredBy": { "type": "string", "description": "The referralCode of the referring user" },
        "referralBalance": { "type": "number", "description": "Withdrawable referral commission balance" }
      },
      "required": ["username", "email", "password", "balance", "isFirstDeposit"]
    },
    "Order": {
      "title": "Order",
      "description": "Lodge request details forwarding social media campaigns target criteria",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "date": { "type": "string" },
        "categoryName": { "type": "string" },
        "serviceId": { "type": "number" },
        "serviceName": { "type": "string" },
        "link": { "type": "string" },
        "quantity": { "type": "number" },
        "charge": { "type": "number" },
        "status": { "type": "string" },
        "startCount": { "type": "number" },
        "refillCount": { "type": "number" }
      },
      "required": ["id", "date", "categoryName", "serviceId", "serviceName", "link", "quantity", "charge", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Payments and campaign expenditure ledger logs",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "method": { "type": "string" },
        "utr": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["id", "date", "method", "utr", "amount", "status"]
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "description": "Support request case logs",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "subject": { "type": "string" },
        "requestType": { "type": "string" },
        "orderId": { "type": "string" },
        "status": { "type": "string" },
        "lastUpdated": { "type": "string" },
        "messages": { "type": "array", "description": "Flattened conversation exchange list" }
      },
      "required": ["id", "subject", "requestType", "status", "lastUpdated", "messages"]
    },
    "WithdrawalRequest": {
      "title": "WithdrawalRequest",
      "description": "Withdrawal request tracking ledger",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "date": { "type": "string" },
        "method": { "type": "string" },
        "amount": { "type": "number" },
        "upiId": { "type": "string" },
        "bankAccount": { "type": "string" },
        "bankIfsc": { "type": "string" },
        "bankName": { "type": "string" },
        "accountHolder": { "type": "string" },
        "status": { "type": "string" },
        "rejectionReason": { "type": "string" }
      },
      "required": ["id", "username", "date", "method", "amount", "status"]
    },
    "GlobalConfig": {
      "title": "GlobalConfig",
      "description": "Global administration overrides like business commission markup percentages",
      "type": "object",
      "properties": {
        "marginPercent": { "type": "number", "description": "Global profit margin markdown from SMM Provider APIs" },
        "festivalTheme": { "type": "string", "description": "Active festival theme keyword (e.g. 'default', 'Diwali', 'Holi')" },
        "festivalGreetingsEnabled": { "type": "boolean", "description": "Toggle to show or hide the festival greetings banner" }
      },
      "required": ["marginPercent"]
    }
  },
  "firestore": {
    "/users/{username}": {
      "schema": "User",
      "description": "Secure client profile ledger"
    },
    "/users/{username}/orders/{orderId}": {
      "schema": "Order",
      "description": "List of placement campaign order requests"
    },
    "/users/{username}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial debit/credit audits"
    },
    "/users/{username}/tickets/{ticketId}": {
      "schema": "SupportTicket",
      "description": "Customer issues and administrative answers ticket tracking"
    },
    "/users/{username}/withdrawals/{withdrawalId}": {
      "schema": "WithdrawalRequest",
      "description": "Withdrawal requests for ledger management"
    },
    "/settings/global": {
      "schema": "GlobalConfig",
      "description": "Global panel specifications set by root administrator"
    }
  }
}
